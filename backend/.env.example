# Node environment
NODE_ENV=development

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/online_db
# OR use individual variables:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=online_db
# DB_USER=postgres
# DB_PASSWORD=postgres

# JWT Secret
JWT_SECRET=replace-with-a-long-random-secret

# Admin access
ADMIN_EMAILS=admin@example.com

# Google sign-in
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Newsletter email notifications
NEWSLETTER_NOTIFICATION_EMAIL=you@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM_NAME=ElectroHub
MAIL_FROM_ADDRESS=you@example.com

# M-Pesa
MPESA_CONSUMER_KEY=your-safaricom-consumer-key
MPESA_CONSUMER_SECRET=your-safaricom-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-m-pesa-passkey
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
